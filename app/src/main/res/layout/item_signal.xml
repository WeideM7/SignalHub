<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#000000"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="#333333"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- 左侧信号等级颜色条 -->
        <View
            android:id="@+id/viewSignalIndicator"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#4CAF50" />

        <!-- 右侧内容区 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- 第一行：图标 + 信号名称 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ivSignalIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="信号类型图标"
                    android:src="@android:drawable/ic_menu_share" />

                <TextView
                    android:id="@+id/tvSignalName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- 第二行：MAC 地址 -->
            <TextView
                android:id="@+id/tvSignalAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#888888"
                android:textSize="12sp" />

            <!-- 第三行：信号强度进度条 + RSSI 值 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:max="100"
                    android:progress="50"
                    android:progressTint="#4CAF50" />

                <TextView
                    android:id="@+id/tvRssi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:minWidth="48dp" />

            </LinearLayout>

            <!-- 第四行：信道信息 -->
            <TextView
                android:id="@+id/tvChannel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#AAAAAA"
                android:textSize="12sp" />

            <!-- 第五行：距离 -->
            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#AAAAAA"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- 右侧锁定按钮 -->
        <ImageView
            android:id="@+id/ivLock"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:contentDescription="锁定信号"
            android:src="@android:drawable/ic_lock_lock"
            android:scaleType="centerInside" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
